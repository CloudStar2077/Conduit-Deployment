backend/**/*.py[cod]
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Python tooling
.pytest_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Django logs
*.log

# SQLite (nur dev)
db.sqlite3
backend/db.sqlite3

# Static & media (generiert)
